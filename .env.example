# Required API Keys
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
EXA_API_KEY=...

# ChromaDB Cloud (required for /api/generate/moe — voice-matched retrieval over scraped posts)
CHROMA_API_KEY=
CHROMA_HOST=
CHROMA_TENANT=
CHROMA_DATABASE=

# Embedding provider for Chroma indexing/query.
# "openai" (text-embedding-3-small, 1536d) | "gemini" (gemini-embedding-001, 3072d)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001

# Mixture-of-experts providers (used by /api/generate/moe).
# Any of these can be omitted — the MoE will skip experts whose key is missing.
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# Optional: Other APIs
TWITTER_API_KEY=
FAL_API_KEY=

# CORS Origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000","https://writer-profile.pages.dev"]
